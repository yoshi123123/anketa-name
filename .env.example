# Скопируй этот файл в .env и поменяй значения
# При деплое на Render — задавай эти переменные в Dashboard → Environment

# Логин и пароль главного админа (создаётся при первом запуске)
OWNER_USERNAME=glom
OWNER_PASSWORD=changeMe_2026!

# Секрет для подписи JWT-токенов. ОБЯЗАТЕЛЬНО смени на длинную случайную строку.
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_long_random_string

# Порт. На Render задаётся автоматически, локально — 3000.
PORT=3000

# Путь к файлу БД. На Render используй /var/data/db.sqlite (с persistent disk).
DB_PATH=./db.sqlite
